# ==========================================
# MedAdhere Workspace-wide .gitignore
# Covers Python backend, React frontend, IoT configurations, and local environments
# ==========================================

# --- Environment and Credentials (CRITICAL) ---
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
backend/.env
frontend/.env
frontend/env (2)
*_tokens.json
_ws_tokens.json
credential.md.local

# --- Python / Django Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
develop-eggs/
/dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
/var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
/ENV/
/env/
# SQLite Database
*.sqlite3
*.sqlite3-journal
db.sqlite3
db.sqlite3-journal

# --- React / Vite Frontend ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
.vite/
*.local
build_log.txt
build_output.txt
frontend/build_log.txt
frontend/build_output.txt

# --- IDEs / Editors / OS files ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
